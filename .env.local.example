NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
OPENAI_API_KEY=sk-proj-...
INTERNAL_API_KEY=change-me
NEXT_PUBLIC_INTERNAL_API_KEY=change-me
# Must match the basePath in next.config.mjs (e.g. /analyze)
NEXT_PUBLIC_BASE_PATH=/analyze

# --- Multi-tenant auth (see src/lib/auth) ---
# HS256 key for signing/verifying session JWTs. Generate with:
#   openssl rand -hex 32
AUTH_SECRET=change-me
# Shared secret between the reverse proxy on client sites and this app. Must
# match ANALYZE_PROXY_SECRET on the main site serving the proxy (e.g. the
# mieuxassure Express app). Generate with:
#   openssl rand -hex 32
PROXY_AUTH_SECRET=change-me
# Hostname where admins (local users) log in with email+password.
ADMIN_HOSTNAME=convanalyzer.messagingme.app
# Bearer token expected by /api/cron/* endpoints (used by Vercel cron).
CRON_SECRET=change-me

